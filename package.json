{
  "name": "code-mobile",
  "private": true,
  "type": "module",
  "workspaces": ["packages/*"],
  "scripts": {
    "dev": "concurrently --kill-others-on-fail --names \"DAEMON,WEB\" -c \"green,blue\" \"bun run dev:daemon\" \"bun run dev:web\"",
    "dev:daemon": "bun --watch packages/daemon/src/index.ts",
    "dev:web": "cd packages/web && bun run dev",
    "build": "bun run build:web",
    "build:web": "cd packages/web && bun run build",
    "lint": "eslint .",
    "test": "bun test --recursive",
    "typecheck": "tsc -b"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@types/bun": "^1.3.10",
    "concurrently": "^9.1.2",
    "eslint": "^9.21.0",
    "globals": "^15.15.0",
    "prettier": "^3.5.3",
    "sharp": "^0.34.5",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.25.0"
  }
}
