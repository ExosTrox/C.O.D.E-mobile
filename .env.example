# ── CODE Mobile — Environment Configuration ─────────────────────
# Copy this file to .env and fill in your values.
# cp .env.example .env

# ── Server ───────────────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0
NODE_ENV=production

# ── Data ─────────────────────────────────────────────────────────
# Where the daemon stores its database, session logs, and hooks.
# In Docker this is mounted as a volume.
DATA_DIR=/home/codemobile/.codemobile

# ── CORS ─────────────────────────────────────────────────────────
# Comma-separated list of allowed origins.
# Set this to your Cloudflare-proxied domain.
CORS_ORIGINS=https://code.gilbergarcia.com

# ── API Keys ─────────────────────────────────────────────────────
# API keys are stored encrypted in the SQLite database, NOT in env vars.
# Users enter their keys in the PWA settings UI.
# The following are only needed if you want to pre-configure keys
# at the system level (optional):
#
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GOOGLE_API_KEY=...
# DEEPSEEK_API_KEY=...
